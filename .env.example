# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=kevin_dev
DB_PASSWORD=
DB_DATABASE=kevin_dev

# Admin account (used by the seeder only)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Umami analytics (optional, e.g. https://analytics.kevin-dev.com/script.js)
UMAMI_SCRIPT_URL=
UMAMI_WEBSITE_ID=

# Umami API access for the admin dashboard stats card (optional,
# all three required; UMAMI_API_URL is the instance origin)
UMAMI_API_URL=
UMAMI_API_USERNAME=
UMAMI_API_PASSWORD=

# When set, the detailed /health report requires this value in the
# x-monitoring-secret header (Uptime Kuma); others get a bare status
MONITORING_SECRET=
DRIVE_DISK=fs

# SMTP relay: shared Proton Mail Bridge, reachable as mailbridge:25 on
# the external `mail` Docker network. Credentials are the Bridge ones
# (not the Proton account), see deploy/mailbridge/README.md in Homelab
SMTP_HOST=mailbridge
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=kevin-dev.com

# Recipient of the contact form notifications (no mail is sent when empty)
CONTACT_NOTIFICATION_EMAIL=